# Supabase — public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://cfbfbzgzqqkrmnjbxeca.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ToEsWt9seTyR3EKvsh4ZFw_B8Gs8_Wq

# Supabase — server only (NEVER expose to browser)
# Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email for submitter confirmation)
# https://resend.com/api-keys
# The sender address (connect@itqan.dev) and bilingual display names
# ("مجتمع إتقان" / "Itqan Community") are hardcoded in src/lib/notify/email.ts.
RESEND_API_KEY=

# Slack — Incoming Webhook URL for new-submission alerts
# Slack App → Features → Incoming Webhooks → Add to a channel
SLACK_WEBHOOK_URL=

# Newsletter — for now we proxy to Itqan's existing endpoint
# Phase 2: switch to direct MailerLite (set MAILERLITE_API_KEY + MAILERLITE_GROUP_ID)
# MAILERLITE_API_KEY is also used by the admin dashboard (لوحة البيانات)
# to pull weekly campaign open-rate stats. With the key unset, the
# dashboard falls back to stats's avgOpenRate or manually-entered values.
NEWSLETTER_PROXY_URL=https://itqan.dev/api/newsletter/subscribe/
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Itqan stats project — Itqan-community/stats. The dashboard pulls live
# values for community engagement (forum), site visits (GA), social reach
# (LinkedIn), publishers + content consumption (Quran Apps directory),
# and community shares (forum posts) from this service.
# Leave blank to fall back to manually-entered values in
# /admin/settings/metrics.
STATS_BASE_URL=
# Optional bearer token if the stats project's endpoints get gated.
# Currently they're public, so this is a forward-compatibility hook.
STATS_API_TOKEN=

# Public site URL — used in emails and Slack messages, and Supabase auth redirects
# Production: https://join.itqan.dev   |  Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry — error monitoring (client + server + edge)
# DSN is safe to expose; on Vercel the Sentry marketplace integration injects all four.
# Leave blank locally to disable Sentry in development.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Build-time only — used by withSentryConfig to upload source maps. Set in CI / Vercel.
SENTRY_AUTH_TOKEN=
